# Banco Neon (desenvolvimento e produção)
#
# No painel do Neon, copie:
# - "Pooled connection" → DATABASE_URL (host com -pooler)
# - "Direct connection"  → DIRECT_URL (host sem -pooler)
#
# A aplicação usa o pooler; migrations usam a conexão direta.

DATABASE_URL="postgresql://usuario:senha@host-pooler.regiao.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@host.regiao.aws.neon.tech/neondb?sslmode=require"

PORT=3001
