datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Campaign {
  id          String        @id @default(uuid())
  nome        String
  descricao   String?
  sistema_rpg String?
  criado_em   DateTime      @default(now())
  excluido_em DateTime?
  players     Player[]
  mainStories MainStory[]
  sideQuests  SideQuest[]
  characters  Character[]
  maps        CampaignMap[]
  combats     Combat[]

  @@map("campaigns")
}

model Image {
  id         String        @id @default(uuid())
  data       Bytes
  mime_type  String
  tamanho    Int
  criado_em  DateTime      @default(now())
  players    Player[]
  characters Character[]
  maps       CampaignMap[]

  @@map("images")
}

model CampaignMap {
  id          String   @id @default(uuid())
  campanha_id String
  campaign    Campaign @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  nome        String
  descricao   String?
  imagem_id   String?
  image       Image?   @relation(fields: [imagem_id], references: [id], onDelete: SetNull)

  @@map("campaign_maps")
}

model Player {
  id                 String              @id @default(uuid())
  campanha_id        String
  campaign           Campaign            @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  nome               String
  raca               String?
  classe             String?
  historia           String?
  imagem_id          String?
  image              Image?              @relation(fields: [imagem_id], references: [id], onDelete: SetNull)
  combatParticipants CombatParticipant[]

  @@map("players")
}

model MainStory {
  id          String   @id @default(uuid())
  campanha_id String
  campaign    Campaign @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  titulo      String
  conteudo    String?
  ordem       Int      @default(1)

  @@map("main_stories")
}

model SideQuest {
  id          String               @id @default(uuid())
  campanha_id String
  campaign    Campaign             @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  titulo      String
  conteudo    String               @default("")
  status      String               @default("INATIVA")
  maps        SideQuestMap[]
  characters  SideQuestCharacter[]

  @@map("side_quests")
}

model SideQuestMap {
  id           String    @id @default(uuid())
  sidequest_id String
  sideQuest    SideQuest @relation(fields: [sidequest_id], references: [id], onDelete: Cascade)
  nome         String
  url_mapa     String

  @@map("side_quest_maps")
}

model Character {
  id                 String               @id @default(uuid())
  campanha_id        String
  campaign           Campaign             @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  nome               String
  titulo             String?
  raca               String?
  classe             String?
  tipo               String // 'NPC' ou 'MOB'
  historia           String?
  caracteristicas    String?
  o_que_sabe         String?
  personalidade      String[]             @default([])
  familia_relacoes   String?
  imagem_id          String?
  image              Image?               @relation(fields: [imagem_id], references: [id], onDelete: SetNull)
  atributos          Json?
  habilidades        Json?
  sideQuests         SideQuestCharacter[]
  combatParticipants CombatParticipant[]

  @@map("characters")
}

model SideQuestCharacter {
  sidequest_id  String
  sideQuest     SideQuest @relation(fields: [sidequest_id], references: [id], onDelete: Cascade)
  personagem_id String
  character     Character @relation(fields: [personagem_id], references: [id], onDelete: Cascade)

  @@id([sidequest_id, personagem_id])
  @@map("side_quest_characters")
}

model Combat {
  id                  String              @id @default(uuid())
  campanha_id         String
  campaign            Campaign            @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  nome_encontro       String
  em_andamento        Boolean             @default(false)
  fase                String              @default("setup")
  tempo_turno_minutos Int                 @default(5)
  rodada_atual        Int                 @default(1)
  turno_atual_index   Int                 @default(0)
  turno_iniciado_em   DateTime?
  encerrado_em        DateTime?
  criado_em           DateTime            @default(now())
  participants        CombatParticipant[]

  @@map("combats")
}

model CombatParticipant {
  id                String               @id @default(uuid())
  combate_id        String
  combat            Combat               @relation(fields: [combate_id], references: [id], onDelete: Cascade)
  jogador_id        String?
  player            Player?              @relation(fields: [jogador_id], references: [id], onDelete: SetNull)
  personagem_id     String?
  character         Character?           @relation(fields: [personagem_id], references: [id], onDelete: SetNull)
  nome_combate      String
  tipo_participante String // 'JOGADOR', 'NPC', 'MOB', 'CUSTOM'
  vida_maxima       Int                  @default(20)
  vida_atual        Int
  ca_atual          Int
  iniciativa        Int?
  ordem_vez         Int                  @default(0)
  status            String               @default("active")
  ativo             Boolean              @default(true)
  atributos         Json?
  habilidades       Json?
  statusEffects     CombatStatusEffect[]

  @@map("combat_participants")
}

model CombatStatusEffect {
  id              String            @id @default(uuid())
  participante_id String
  participant     CombatParticipant @relation(fields: [participante_id], references: [id], onDelete: Cascade)
  nome_efeito     String
  tipo            String // 'BUFF' ou 'DEBUFF'
  duracao_rodadas Int?
  ativo           Boolean?

  @@map("combat_status_effects")
}
